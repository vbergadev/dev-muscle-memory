# Copy to `.env` and adjust as needed.
# Used from week 16 on (Postgres via Docker) and in Phase 4.

POSTGRES_USER=devlab
POSTGRES_PASSWORD=devlab
POSTGRES_DB=devlab

# Host port. If you already run a Postgres on 5432, change it here (e.g. 5433)
# and update DATABASE_URL below to match.
POSTGRES_PORT=5432

DATABASE_URL=postgres://devlab:devlab@localhost:5432/devlab
